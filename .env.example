# Database
POSTGRES_USER=cs2match
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cs2match
DATABASE_URL=postgresql+asyncpg://cs2match:changeme@postgres:5432/cs2match

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_SECRET_KEY=change-this-to-a-long-random-string
API_SYNC_TOKEN=change-this-sync-token
MY_STEAM64_ID=

# Steam Web API
STEAM_API_KEY=

# Steam GC bot account (secondary account for server-side GC connection)
STEAM_BOT_USERNAME=
STEAM_BOT_PASSWORD=
# Required if bot uses Mobile Authenticator (TOTP): shared_secret from .maFile
STEAM_BOT_SHARED_SECRET=
# Recommended: mount full .maFile (uses Session.RefreshToken — no TOTP each login)
STEAM_BOT_MAFILE_HOST_PATH=./secrets
STEAM_BOT_MAFILE_PATH=/run/secrets/maFile.json
# Cooldown after AccountLoginDeniedThrottle (default 30 min)
STEAM_LOGIN_THROTTLE_MS=1800000

# Your match history credentials (one-time setup via web UI, can also set here)
STEAM_AUTH_CODE=
STEAM_OLDEST_SHARE_CODE=

# FACEIT
FACEIT_API_KEY=
FACEIT_NICKNAME=

# Leetify (optional)
LEETIFY_API_KEY=
# Browser session JWT for full match history (games/history). Paste once in Settings or set here.
# Also written to .env automatically when you save in the web UI.
LEETIFY_SESSION_TOKEN=

# Web (host port — default 3472 avoids common 3000/3001 conflicts)
WEB_PORT=3472
# Optional: only needed if not using the built-in Next.js API proxy
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Worker / sync intervals (seconds)
SYNC_POLL_INTERVAL=300
# Delay between Steam share-code chain steps (ms). Lower = faster sync, higher GC load. Default 500.
SYNC_MATCH_DELAY_MS=500

# FACEIT sync: max matches per run (default 2000). Each match needs several API calls.
FACEIT_SYNC_MAX_MATCHES=2000
